# Morph Hoodi testnet full node (morph-geth + morph-node, MPT mode)
# ./configure.sh hoodi && ./init-database.sh hoodi && ./create-jwt.sh && docker compose up -d
#
# L1 is Ethereum Hoodi (chain ID 560048), not Sepolia.
# Chain data: $HOME/morph-hoodi-geth-data, $HOME/morph-hoodi-node-data

GETH_DATADIR=$HOME/morph-hoodi-geth-data
NODE_DATADIR=$HOME/morph-hoodi-node-data

GETH_IMAGE=ghcr.io/morph-l2/go-ethereum:2.2.3
NODE_IMAGE=ghcr.io/morph-l2/node:0.5.7

HTTP_HOST_PORT=8441
WS_HOST_PORT=8442
GETH_P2P_PORT=10303
GETH_METRICS_HOST_PORT=16060
NODE_RPC_HOST_PORT=12657
NODE_P2P_PORT=10656
NODE_METRICS_HOST_PORT=12660

EXT_IP=<YOUR_PUBLIC_IP>

MORPH_FLAG=morph-hoodi
NODE_EXTRA_FLAGS=

L1_CHAIN_ID=560048
L1_ETH_RPC=<YOUR_L1_ETH_RPC>

ROLLUP_CONTRACT=0x57e0e6dde89dc52c01fe785774271504b1e04664

# Must match the snapshot you restore (latest: snapshot-archive-20260630-1)
L1_MSG_START_HEIGHT=3106743

SNAPSHOT_NAME=snapshot-archive-20260630-1
