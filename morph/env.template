# Morph mainnet full node (morph-geth + morph-node, MPT mode)
# ./configure.sh && ./init-database.sh && ./create-jwt.sh && docker compose up -d
#
# Authoritative source: https://github.com/morph-l2/run-morph-node
# Chain data: $HOME/morph-geth-data, $HOME/morph-node-data

GETH_IMAGE=ghcr.io/morph-l2/go-ethereum:2.2.3
NODE_IMAGE=ghcr.io/morph-l2/node:0.5.7

# Host port bindings (RPC on localhost only)
HTTP_HOST_PORT=8441
WS_HOST_PORT=8442
GETH_P2P_PORT=10303
GETH_METRICS_HOST_PORT=16060
NODE_RPC_HOST_PORT=12657
NODE_P2P_PORT=10656
NODE_METRICS_HOST_PORT=12660

EXT_IP=<YOUR_PUBLIC_IP>

# Max blocks for eth_getTransaction* lookups (0 = unlimited)
# Morph default: 2350000 (~1 year of blocks)
GETH_TX_LOOKUP_LIMIT=0

# Geth garbage-collection mode: archive | full
GETH_GCMODE=archive

# Morph network flags (mainnet MPT)
MORPH_FLAG=morph
NODE_EXTRA_FLAGS=--mainnet

# L1 Ethereum mainnet (required)
L1_CHAIN_ID=1
L1_ETH_RPC=<YOUR_L1_ETH_RPC>

# L1 contracts (from run-morph-node morph-node/.env)
ROLLUP_CONTRACT=0x759894ced0e6af42c26668076ffa84d02e3cef60

# Must match the snapshot you restore (latest: snapshot-archive-20260701-1)
L1_MSG_START_HEIGHT=25439950

# Snapshot name for manual download — see README
SNAPSHOT_NAME=snapshot-archive-20260701-1
