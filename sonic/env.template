# Sonic mainnet RPC node (sonicd)
# cp env.template .env and configure before running
#
# Setup:
#   1. ./configure.sh
#   2. curl -JLO https://genesis.soniclabs.com/latest-sonic-pruned.g
#   3. mv latest-sonic-pruned.g $HOME/sonic.g
#   4. docker compose build
#   5. ./sonic-init.sh
#   6. docker compose up -d
#
# Snapshot flow: download a genesis from https://genesis.soniclabs.com/, run sonic-init.sh, then compose up
#
# Docs: https://docs.soniclabs.com/sonic/node-deployment/archive-node
# Client: https://github.com/0xsoniclabs/sonic/releases

# Public IP for P2P advertisement (--nat extip); required for incoming peers
EXT_IP=

### Sonic release (0xsoniclabs/sonic) — baked into local image at build time ###
SONIC_VERSION=2.1.3

### Host paths ###
# Chain data (docker volume mount target inside container: /data)
HOST_DATADIR=$HOME/sonic-data

### Ports (host; network_mode: host) ###
HTTP_ADDR=0.0.0.0
HTTP_PORT=18545
WS_ADDR=0.0.0.0
WS_PORT=18546
MAX_PEERS=32

### RPC ###
HTTP_API=eth,web3,net,txpool,abft,dag,trace,debug
WS_API=eth,web3,net,txpool,abft,dag,trace,debug
GAS_CAP=600000000
TX_FEE_CAP=0

### Performance ###
GOMEMLIMIT=32GiB
CACHE_MB=24000
# Container mem_limit (must exceed GOMEMLIMIT and CACHE_MB)
MEM_LIMIT=42g
