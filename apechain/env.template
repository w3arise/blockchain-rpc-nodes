# ApeChain mainnet replica (Caldera Nitro, pruned)
# Requires a synced Arbitrum One RPC — use arbitrum/ or a private endpoint.
# cp env.template .env && docker compose up -d

NITRO_IMAGE=public.ecr.aws/i6b2w2n6/nitro-node:apechain-v3.5.6

HTTP_PORT=8747
WS_PORT=8748

# Parent chain: Arbitrum One (chain 42161). Do not use the public RPC in production.
PARENT_CHAIN_RPC=

FORWARDING_TARGET=https://apechain.calderachain.xyz/http
FEED_URL=wss://apechain.calderachain.xyz/feed
REST_AGGREGATOR_URL=https://apechain.calderachain.xyz/rest-aggregator

# Optional first-run snapshot (empty datadir only). Remove flag after init.
# SNAPSHOT_URL=https://caldera-chain-data-snapshots.s3.us-west-2.amazonaws.com/exported-snapshots/nitro-apechain/nitro-apechain-2025-Sep-22.tar
