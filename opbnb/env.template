# opBNB mainnet (op-geth + op-node)
# ./configure.sh && ./create-jwt.sh && docker compose up -d
#
# Image tags: https://github.com/bnb-chain/op-geth/releases
#             https://github.com/bnb-chain/opbnb/releases

OP_GETH_IMAGE_TAG=v0.5.10
OP_NODE_IMAGE_TAG=v0.5.5

# Public IP for P2P advertisement (op-geth --nat=extip, op-node --p2p.advertise.ip).
# Resolved by ./configure.sh (curl ip.me); override manually if needed.
EXT_IP=<YOUR_PUBLIC_IP>

# BSC L1 RPC (prefer your own endpoint)
OP_NODE__RPC_ENDPOINT=<YOUR_BSC_RPC>

# Sequencer HTTP (op-geth)
L2_RPC=https://opbnb-mainnet-rpc.bnbchain.org

GAS_CAP=600000000

OP_GETH_P2P_PORT=37307
PORT__OP_NODE_P2P=9003

