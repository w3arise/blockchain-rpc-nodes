# Bitlayer (bitlayer-l2 geth) mainnet RPC node
# cp env.template .env and configure before running
#
# Setup:
#   1. ./configure.sh
#   2. docker compose build
#   3. ./init-database.sh
#   4. docker compose up -d
#
# Snapshot flow: restore chain data into $HOME/bitlayer-data, skip init-database.sh
#
# Docs: https://docs.bitlayer.org/docs/Build/GettingStarted/CompileAndRun/
# Client: https://github.com/bitlayer-org/bitlayer-l2

### Network ###
# mainnet (chain ID 200901) or testnet (chain ID 200810)
NETWORK=mainnet

# Public IP for P2P advertisement (--nat extip); required for incoming peers
EXT_IP=

### Geth release (bitlayer-org/bitlayer-l2) — baked into local image at build time ###
GETH_VERSION=v1.1.10

### Host paths ###
# Chain data (docker volume mount target inside container: /data)
HOST_DATADIR=$HOME/bitlayer-data

### Ports (host) ###
P2P_PORT=31031
HTTP_PORT=8145
WS_PORT=8146
AUTHRPC_PORT=8445

### Sync ###
# Full RPC node: snap + full GC. Archive: full + archive (see README).
SYNC_MODE=snap
GCMODE=full
MAX_PEERS=50
VERBOSITY=3
TRACEACTION=2

