# Hemi mainnet (hemi-min profile: op-geth + op-node + bssd)
# ./configure.sh && ./create-jwt.sh && docker compose up -d
#
# Image pins from https://github.com/hemilabs/hemi-node (mainnet/docker-compose.yml)
# Docs: https://github.com/hemilabs/hemi-node/blob/main/NODE_RUNNING.md

OP_GETH_IMAGE=ghcr.io/hemilabs/op-geth:05d4d8f@sha256:92d14f0b4b89947352d57743ce9e7f2d9c9e495f0bb861a24d21c49d391c7abf
OP_NODE_IMAGE=ghcr.io/hemilabs/op-node:7c70d2d@sha256:7db35d5798615e572d80823a3238a8111b14a90aade876a34b6a2936b17cbd87
BSSD_IMAGE=hemilabs/bssd:1.6.3@sha256:b6782c25b3245f1cede1d7b75bbea4d9fe36f2dc4fa708a9fae03b1f34ee7126

# Public IP for P2P (op-geth --nat, op-node --p2p.advertise.ip).
# Resolved by ./configure.sh (curl ip.me); override manually if needed.
EXT_IP=<YOUR_PUBLIC_IP>

# Ethereum L1 (required for hemi-min)
GETHL1ENDPOINT=<YOUR_ETH_EXECUTION_RPC>
PRYSMENDPOINT=<YOUR_ETH_BEACON_RPC>

# Snap sync via execution-layer (official hemi-min default)
OPSYNCMODE=execution-layer

GAS_CAP=600000000

# Host bind address for published RPC ports (127.0.0.1 = localhost only; 0.0.0.0 = all interfaces)
RPC_BIND_ADDR=127.0.0.1

# RPC ports (host publish and container listen use the same values)
OP_GETH_HTTP_PORT=7145
OP_GETH_WS_PORT=7146
OP_NODE_RPC_PORT=7147
BSS_RPC_PORT=8081

OP_GETH_P2P_PORT=30303
OP_NODE_P2P_PORT=9003

# Optional host datadir overrides (defaults shown)
# HEMI_GETH_DATA=$HOME/hemi-op-geth-data
# HEMI_TBC_DATA=$HOME/hemi-tbc-data
# HEMI_OP_NODE_DATA=$HOME/hemi-op-node-data

# bssd BFG WebSocket (official default; unused without a local bfgd)
# BSS_BFG_URL=ws://bfgd:8080/v1/ws/private
