# Arbitrum Node Configuration

# Docker Image Version
NITRO_IMAGE=offchainlabs/nitro-node:v3.7.3-e421729


# Networking
# Port exposed for HTTP JSON-RPC and WebSocket
HTTP_PORT=8647
WS_PORT=8648

# API Configuration
# Exposed APIs for HTTP and WebSocket
HTTP_API=net,web3,eth,arb,trace
WS_API=net,web3,eth,arb,trace

# Layer 1 (Ethereum) Configuration
# URL for Layer 1 Ethereum RPC (Required)
L1_URL=
# URL for Layer 1 Beacon Chain (Required for blob support)
L1_BEACON_URL=

# Chain Configuration
CHAIN_ID=42161
# Feed URL (Defaults to Arbitrum One) - the official sequencer feed for the One mainnet
FEED_URL=wss://arb1.arbitrum.io/feed

# Node Settings
LOG_LEVEL=3
TX_FEE_CAP=90000000000000
GAS_CAP=90000000000000

# State trie storage scheme: hash or path
STATE_SCHEME=path
STATE_HISTORY=0
#├── Basis: 250ms block time (verified from docs' own default: 24h = 345,600 blocks)
#├── "Month" is ambiguous — pick the one matching your actual definition:
#│   ├── 28 days → 9,676,800 blocks
#│   ├── 30 days → 10,368,000 blocks   ← most common convention
#│   ├── 31 days → 10,713,600 blocks
#│   └── 365/12 avg → 10,512,000 blocks
