# Gnosis mainnet node (reth_gnosis + lighthouse)
# cp env.template .env && ./create-jwt.sh && docker compose up -d
#
# Data directories (docker-compose volume mounts):
#   $HOME/gnosis-reth-data        — execution client chain data
#   $HOME/gnosis-lighthouse-data  — consensus client chain data

### Docker images ###
GNOSIS_RETH_IMAGE=ghcr.io/gnosischain/reth_gnosis:v2.0.0
LIGHTHOUSE_IMAGE=sigp/lighthouse:v8.2.0

### Networking — required for public P2P ###
EXT_IP=<YOUR_PUBLIC_IP>
P2P_PORT=25025
HTTP_PORT=9045
WS_PORT=9046
BEACON_P2P_PORT=9001
BEACON_HTTP_PORT=5052

### RPC ###
GAS_CAP=610000000

### Lighthouse checkpoint sync ###
CHECKPOINT_SYNC_URL=https://checkpoint.gnosischain.com
