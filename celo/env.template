# Celo mainnet L2 node (celo-op-reth + op-node + EigenDA)
# ./configure.sh && ./create-jwt.sh && docker compose up -d
#
# Built-in chain presets: op-reth --chain=celo, op-node OP_NODE_NETWORK=celo-mainnet
# Images from celo-org/celo-l2-node-docker-compose (celo-v1.0.0 / celo-v2.2.1)

OP_RETH_IMAGE=us-west1-docker.pkg.dev/devopsre/celo-blockchain-public/op-reth:celo-v1.0.0
OP_NODE_IMAGE=us-west1-docker.pkg.dev/devopsre/celo-blockchain-public/op-node:celo-v2.2.1
EIGENDA_PROXY_IMAGE=ghcr.io/layr-labs/eigenda-proxy:v2.6.0

# Node tier + snapshot tier: minimal | full | archive
NODE_TYPE=full
OP_RETH_SNAPSHOT=true
OP_RETH_CHAIN=celo
OP_RETH_SEQUENCER_URL=https://cel2-sequencer.celo.org
# Optional: remote pre-L2 historical RPC (archive operators)
# OP_RETH_HISTORICAL_RPC=https://your-legacy-archive.example

RETH_PORT=10401
OP_NODE_P2P_PORT=10422
EXT_IP=<YOUR_PUBLIC_IP>

