# X Layer mainnet — setup (snapshot flow):
#   1. ./create-jwt.sh          # generate config/jwt.txt (shared Engine API secret)
#   2. cp env.template .env     # then set L1_RPC_URL / L1_BEACON_URL
#   3. restore op-geth data from snapshot into $HOME/data-mainnet
#   4. docker compose up -d
# Config (rollup + op-geth toml) is committed under config/.
# From scratch instead of snapshot? run ./init-database.sh (genesis + geth init).
#
# Two stacks run together:
#   1. OP Stack (op-geth + op-node) — current chain; live sync and public RPC
#   2. CDK Erigon — legacy Polygon CDK node; archival backend only (no sync)
#      op-geth forwards historical/trace RPC to cdk-erigon via X_LAYER_PP_RPC_URL


###############################################################################
# OP Stack — current chain (op-geth + op-node)
###############################################################################

### Layer 1 (Ethereum) — required ###
L1_RPC_URL=<YOUR_L1_ETH_RPC>
L1_BEACON_URL=<YOUR_L1_BEACON>

# Bootnodes (op-node only; also hardcoded in docker-compose.yml today)
OP_NODE_BOOTNODE=enode://c67d7f63c5483ab8311123d2997bfe6a8aac2b117a40167cf71682f8a3e37d3b86547c786559355c4c05ae0b1a7e7a1b8fde55050b183f96728d62e276467ce1@8.210.177.150:9223,enode://28e3e305b266e01226a7cc979ab692b22507784095157453ee0e34607bb3beac9a5b00f3e3d7d3ac36164612ca25108e6b79f75e3a9ecb54a0b3e7eb3e097d37@8.210.15.172:9223,enode://b5aa43622aad25c619650a0b7f8bb030161dfbfd5664233f92d841a33b404cea3ffffdc5bc8d6667c7dc212242a52f0702825c1e51612047f75c847ab96ef7a6@8.210.69.97:9223

### Docker images ###
OP_STACK_IMAGE_TAG=xlayer/op-node:v0.1.5
OP_GETH_IMAGE_TAG=xlayer/op-geth:v0.1.5.3

# Archival RPC backend (cdk-erigon service on docker network)
X_LAYER_PP_RPC_URL=http://xlayer-cdk-erigon:8545

# Host data directories (under $HOME, see docker-compose.yml volume mounts)
#   $HOME/data-mainnet           — op-geth chain data
#   $HOME/xlayer-op-node-data    — op-node state (safedb, p2p)
#   $HOME/erigon-data            — cdk-erigon archival chain data


###############################################################################
# CDK Erigon — legacy chain (archival backend for op-geth pp-rpc-url)
###############################################################################

# Git ref/tag for okx/xlayer-erigon (local build + image tag)
# Example: v0.9.2 (matches Dockerfile default)
ERIGON_VERSION=v0.9.2

# Container datadir mount target
DATADIR=/home/erigon-data

# Resource limit (shared by cdk-erigon service)
MEM_LIMIT=16g

# L1 RPC for zkEVM contract reads (can match L1_RPC_URL above)
ZKEVM_L1_RPC_URL=<YOUR_L1_ETH_RPC>
