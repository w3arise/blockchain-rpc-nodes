# Cronos mainnet full node (cronosd)
# cp env.template .env and configure before running
#
# Setup:
#   1. ./configure.sh
#   2. docker compose build
#   3. ./init-database.sh
#   4. docker compose up -d
#
# Snapshot flow: restore a default LevelDB snapshot into $HOME/cronos-data, then
# patch app.toml (see README) and skip a wipe/re-init.
#
# Docs: https://docs.cronos.com/for-node-hosts/running-nodes/cronos-mainnet
# Client: https://github.com/crypto-org-chain/cronos

### Network ###
CHAIN_ID=cronosmainnet_25-1
MONIKER=cronos-rpc

# Public IP for P2P advertisement (external_address); required for incoming peers
EXT_IP=

### Host user (baked into image at build time) ###
# Set by ./configure.sh — re-run configure + docker compose build if your uid/gid changes
BUILD_UID=1000
BUILD_GID=1000

### cronosd release (crypto-org-chain/cronos) — baked into local image at build time ###
# Pins the GitHub release tarball and the local Docker tag (cronosd:<version>).
CRONOS_VERSION=1.7.8

### Host paths ###
# Chain data (docker volume mount target inside container: /data); --home /data
# Leave unset to use $HOME/cronos-data (resolved when you run docker compose / scripts)
# HOST_DATADIR=$HOME/cronos-data

### Ports ###
# JSON-RPC / Tendermint RPC / Cosmos API bind on localhost by default
RPC_BIND_ADDR=127.0.0.1
HTTP_PORT=8545
WS_PORT=8546
TM_RPC_PORT=26657
API_PORT=1317
GRPC_PORT=9090
# CometBFT P2P (TCP + UDP), public
P2P_PORT=26656

### app.toml (applied by init-database.sh) ###
# Private endpoint defaults from operators; validators often use a higher min gas price.
PRUNING=default
MINIMUM_GAS_PRICES=1basecro
LOGS_CAP=100000
BLOCK_RANGE_CAP=100000
# eth_call / estimateGas cap (repo default 600M)
GAS_CAP=600000000

