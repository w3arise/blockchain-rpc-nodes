# Robinhood Chain mainnet archive node (Arbitrum Nitro)
# Requires synced Ethereum L1 execution + beacon endpoints.
# cp env.template .env && docker compose up -d

NITRO_IMAGE=offchainlabs/nitro-node:v3.11.1-8512b8c

HTTP_PORT=8847
WS_PORT=8848

HTTP_API=net,web3,eth,arb
WS_API=net,web3,eth,arb

# Layer 1 (Ethereum) — required for blob data availability
L1_ETH_URL=
L1_ETH_BEACON_URL=

CHAIN_ID=4663
FEED_URL=wss://feed.mainnet.chain.robinhood.com

TX_FEE_CAP=90000000000000
GAS_CAP=90000000000000
STATE_SCHEME=path
# 0 = unlimited (archive). Non-zero prunes history — see README and AGENTS.md.
STATE_HISTORY=0

# Optional first-run snapshot (empty datadir only). Remove after init.
# INIT_URL=
