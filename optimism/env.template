# Names containers/networks/volumes (default is the directory name).
# COMPOSE_PROJECT_NAME=optimism


OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.17.0
OP_RETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-reth:v2.2.1

# Comma-separated JSON-RPC namespaces over HTTP (op-reth --http.api)
OP_RETH_HTTP_API=eth,net,web3,debug,trace,txpool,admin
# Comma-separated JSON-RPC namespaces over WebSocket (op-reth --ws.api)
OP_RETH_WS_API=eth,net,web3,debug,trace,txpool


### op-reth RPC limits (optional; compose defaults match previous hardcoded values) ###
OP_RETH_RPC_MAX_CONNECTIONS=2000
OP_RETH_RPC_CACHE_MAX_BLOCKS=20000
OP_RETH_RPC_CACHE_MAX_RECEIPTS=20000
OP_RETH_RPC_CACHE_MAX_HEADERS=20000
OP_RETH_RPC_GASCAP=600000000
OP_RETH_RPC_CACHE_MAX_CONCURRENT_DB_REQUESTS=2000
OP_RETH_ENGINE_CROSS_BLOCK_CACHE_SIZE=10240
OP_RETH_ROLLUP_SEQUENCER=https://mainnet-sequencer.optimism.io/


### Layer 1 (Ethereum) ###
L1_RPC=<YOUR_L1_RPC>
L1_BEACON=<YOUR_L1_BEACON>


### Networking — required for public P2P ###
EXT_IP=<YOUR_PUBLIC_IP>
P2P_PORT=<YOUR_P2P_PORT>
