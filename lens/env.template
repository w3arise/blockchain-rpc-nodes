# Lens mainnet external node (ZK Stack Validium + Avail DA)
# cp env.template .env && ./configure.sh && docker compose up -d
#
# Chain data: $HOME/lens-postgres-data, $HOME/lens-rocksdb-data

EN_VERSION=v29.1.2
EN_MAIN_NODE_URL=https://rpc.lens.xyz
EN_L1_CHAIN_ID=1
EN_L2_CHAIN_ID=232
EN_L1_BATCH_COMMIT_DATA_GENERATOR_MODE=Validium

# Required — use your own Ethereum mainnet JSON-RPC
EN_ETH_CLIENT_URL=<YOUR_L1_ETH_RPC>

# Change before production use
DB_PASSWORD=notsecurepassword

# Avail DA — leave empty; ./configure.sh generates a fresh BIP39 phrase
EN_DA_SECRETS_SEED_PHRASE=

# RPC ports (localhost only)
EN_HTTP_PORT=3060
EN_WS_PORT=3061
EN_HEALTHCHECK_PORT=3081

# Snapshot recovery from GCS (must stay enabled on first start)
EN_SNAPSHOTS_RECOVERY_ENABLED=true
EN_SNAPSHOTS_OBJECT_STORE_BUCKET_BASE_URL=raas-lens-mainnet-external-node-snapshots

# Pruning — retains recent L1 batches (~7 days default); no full state history
EN_PRUNING_ENABLED=true
