# Katana mainnet (conduit-op-reth + op-node)
#
# Setup:
#   1. ./configure.sh                 # create .env and set EXT_IP
#   2. Edit .env: OP_NODE_L1_ETH_RPC, OP_NODE_L1_BEACON
#   3. ./create-jwt.sh
#   4. docker compose up -d
#
# Chain ID 747474. Genesis/rollup from:
#   https://github.com/katana-network/network-configs (mainnet/op-reth/)
# Conduit slug: katana — https://hub.conduit.xyz/katana

### Images ###
OP_RETH_IMAGE=ghcr.io/conduitxyz/conduit-op-reth:v2.1.1
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.19.2

### Network ###
# Public IP for P2P advertisement (--nat extip / OP_NODE_P2P_ADVERTISE_IP)
EXT_IP=

### Host paths ###
HOST_DATADIR=$HOME/katana-op-reth-data
HOST_OP_NODE_DATADIR=$HOME/katana-op-node-data

### Ports (host = container) ###
HTTP_PORT=8441
WS_PORT=8442
AUTHRPC_PORT=9551
P2P_PORT=10301

### RPC ###
GAS_CAP=600000000

### op-node L1 ###
OP_NODE_L1_ETH_RPC=<YOUR_L1_ETH_RPC>
OP_NODE_L1_BEACON=<YOUR_L1_BEACON>
OP_NODE_L1_TRUST_RPC=true
OP_NODE_L1_RPC_KIND=standard
OP_NODE_L1_MAX_CONCURRENCY=20
OP_NODE_L1_RPC_MAX_BATCH_SIZE=50

### op-node L2 / rollup ###
OP_NODE_LOG_LEVEL=INFO
OP_NODE_L2_ENGINE_KIND=reth
OP_NODE_L2_ENGINE_AUTH=/config/jwt.hex
# Engine RPC URL is set in docker-compose.yml from AUTHRPC_PORT
OP_NODE_SYNCMODE=execution-layer
OP_NODE_ROLLUP_CONFIG=/config/rollup.json
OP_NODE_RPC_ENABLE_ADMIN=true
OP_NODE_SAFEDB_PATH=/data
OP_NODE_METRICS_ENABLED=true
OP_NODE_METRICS_ADDR=127.0.0.1
OP_NODE_ALTDA_ENABLED=false
OP_NODE_VERIFIER_L1_CONFS=15
# Fork overrides from network-configs / Conduit forkTimestamps (not all in rollup.json)
OP_NODE_OVERRIDE_ISTHMUS=1746806401
OP_NODE_OVERRIDE_JOVIAN=1773066601

