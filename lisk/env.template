# Lisk mainnet rollup node (op-reth + op-node)
#
# Setup:
#   1. ./configure.sh                 # create .env and set public IP
#   2. Edit .env: OP_NODE_L1_ETH_RPC, OP_NODE_L1_BEACON
#   3. ./create-jwt.sh
#   4. docker compose up -d
#
# Uses built-in superchain presets — no local genesis/rollup files required.
# Chain spec: op-reth --chain=lisk, op-node OP_NODE_NETWORK=lisk-mainnet
# Official guide: https://github.com/LiskHQ/lisk-node

### Images ###
OP_RETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-reth:v2.4.0
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.19.3

### Network ###
# Public IP for P2P advertisement (--nat extip / OP_NODE_P2P_ADVERTISE_IP)
EXT_IP=

### Host paths ###
HOST_DATADIR=$HOME/lisk-op-reth-data
HOST_OP_NODE_DATADIR=$HOME/lisk-op-node-data

### Ports (host → container 8545 / 8546 / op-node RPC) ###
RPC_BIND_ADDR=127.0.0.1
HTTP_PORT=8741
WS_PORT=8742
OP_NODE_RPC_PORT=8743
OP_NODE_P2P_PORT=9222
P2P_PORT=10411

### RPC ###
GAS_CAP=600000000

### op-reth P2P (snap / peer bootstrap; from LiskHQ/lisk-node .env.mainnet) ###
OP_RETH_BOOTNODES=enode://c113be206722079300449e42382bb9d1e123362f2b63d954cba896a3e6741ebe446fdb46ed77a32da1b3288384d36ea17847954b56c36bb28a00f3a689fdf916@35.234.171.144:9003?discport=9004

### op-node L1 ###
OP_NODE_L1_ETH_RPC=<YOUR_L1_ETH_RPC>
OP_NODE_L1_BEACON=<YOUR_L1_BEACON>
OP_NODE_L1_TRUST_RPC=true
OP_NODE_L1_RPC_KIND=standard
OP_NODE_L1_MAX_CONCURRENCY=20
OP_NODE_L1_RPC_MAX_BATCH_SIZE=50

### op-node L2 / rollup ###
OP_NODE_LOG_LEVEL=INFO
OP_NODE_L2_ENGINE_KIND=reth
OP_NODE_L2_ENGINE_AUTH=/config/jwt.hex
OP_NODE_L2_ENGINE_RPC=http://lisk-op-reth:9551
OP_NODE_SYNCMODE=execution-layer
OP_NODE_NETWORK=lisk-mainnet
OP_NODE_SYNCMODE_REQ_RESP=true
OP_NODE_ROLLUP_LOAD_PROTOCOL_VERSIONS=true
OP_NODE_RPC_ADDR=0.0.0.0
OP_NODE_RPC_ENABLE_ADMIN=true
OP_NODE_SAFEDB_PATH=/data
OP_NODE_METRICS_ENABLED=true
OP_NODE_METRICS_ADDR=127.0.0.1
OP_NODE_VERIFIER_L1_CONFS=4

### op-node P2P (from LiskHQ/lisk-node .env.mainnet) ###
OP_NODE_P2P_LISTEN_IP=0.0.0.0
OP_NODE_P2P_LISTEN_TCP=9222
OP_NODE_P2P_LISTEN_UDP=9222
OP_NODE_P2P_BOOTNODES=enr:-Iu4QBCIUw0OhAq5ErARIYBLIr6xPb83OqeFRqlUJGlJ9kWpNECaumPArYWsEFdM_cEKm26JJT_EA52f4dlavBldldgBgmlkgnY0gmlwhCPqq5CJc2VjcDI1NmsxoQLBE74gZyIHkwBEnkI4K7nR4SM2Lytj2VTLqJaj5nQevoN0Y3CCIyuDdWRwgiMs
OP_NODE_P2P_STATIC=/ip4/34.12.217.4/tcp/9003/p2p/16Uiu2HAmGozvwRfvZkcET659CPuYS8edK1dWMNGtDYvxcNN6Le4P
OP_NODE_P2P_ADVERTISE_IP=

# Lisk Sepolia: edit docker-compose.yml (--chain=lisk-sepolia,
# sequencer https://rpc.sepolia-api.lisk.com) and swap L1 + network vars:
#   OP_NODE_NETWORK=lisk-sepolia
#   OP_NODE_L1_ETH_RPC / OP_NODE_L1_BEACON → Sepolia
