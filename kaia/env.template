# Kaia mainnet Endpoint Node (ken)
# cp env.template .env and configure before running
# docker compose up -d

# Docker image — https://hub.docker.com/r/kaiachain/kaia/tags
KAIA_IMAGE=kaiachain/kaia:v2.2.2

# Host path for chain data (used in volume mount)
# Leave unset to use $HOME/kaia-data (resolved when you run docker compose)
# HOST_DATADIR=$HOME/kaia-data

# Public IP for P2P advertisement (required for incoming peers with bridged ports)
EXT_IP=

# Host port mappings (container ports are fixed in config/kend.conf)
HTTP_PORT=8551
WS_PORT=8552
P2P_PORT=32323
P2P_SUBPORT=32324
METRICS_PORT=61001
