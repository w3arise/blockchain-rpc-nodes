# AB Core mainnet RPC node (abcore geth fork)
# cp env.template .env and configure before running
#
# Setup:
#   1. ./configure.sh               # create .env and set EXT_IP
#   2. docker compose build
#   3. ./init-database.sh            # mainnet (default)
#   4. docker compose up -d
#
# Snapshot: no official chaindata snapshot documented — sync from genesis/P2P.
#
# Docs: https://docs.ab.org/docs/
# Binary: https://github.com/ABFoundationGlobal/abcore/releases
# Genesis/bootnodes: https://github.com/ABFoundationGlobal/ab-deploy

### Network ###
NETWORK=mainnet
# mainnet 36888, testnet 26888
NETWORK_ID=36888

# Public IP for P2P advertisement (--nat extip); required for incoming peers
EXT_IP=

### Geth release (ABFoundationGlobal/abcore) — baked into local image at build time ###
GETH_VERSION=v1.13.15-abcore-1.2

### Host paths ###
HOST_DATADIR=$HOME/ab-data

### Ports (host) ###
P2P_PORT=33333
HTTP_PORT=8545
WS_PORT=8546
METRICS_PORT=6360

### Sync / retention (matches ab-deploy node.toml defaults) ###
SYNC_MODE=full
GCMODE=full
STATE_HISTORY=90000
HISTORY_TRANSACTIONS=0
# Total geth DB/cache budget (MB). Official ab-deploy uses 512; raise for RPC on 16GB+ hosts.
CACHE=8192

### Peers ###
MAX_PEERS=20

### Bootnodes (official ab-deploy abcore/mainnet/conf/node.toml) ###
