### RPC ###
GAS_CAP=600000000
RPC_EVM_TIMEOUT=5s
RPC_TX_FEE_CAP=10000
RPC_BATCH_REQUEST_LIMIT=1000
RPC_BATCH_MAX_SIZE=25000000
HTTP_API=debug,txpool,net,web3,eth
WS_API=debug,txpool,net,web3,eth

### Tx pool (official defaults) ###
TXPOOL_PRICE_LIMIT=50000000000000

### Logging ###
VERBOSITY=3
