# =============================================================================
# ONE-TIME SETUP (before first docker compose up)
# =============================================================================
# 1. cp env.template .env
# 2. Fill .env: L1_RPC, L1_BEACON, EXT_IP (and RONIN_NETWORK / datadirs if you change defaults).
# 3. ./init-datadirs.sh — creates host datadirs (RONIN_* paths below), jwt.hex, genesis.json,
#    rollup.json, and applies the Conduit alt_da jq patch on rollup.json (required with --altda.enabled).
#    Re-run with ./init-datadirs.sh --force to refresh downloads or JWT; re-run without --force to re-apply the alt_da patch if op-node fails with "no altDA config".
# 4. Add Conduit snapshot / chain data under RONIN_RETH_DATADIR if required (see Conduit Ronin docs).
# 5. docker compose --env-file .env up -d
# Optional: COMPOSE_PROJECT_NAME=ronin  (default project name is usually the directory name)
# =============================================================================

######## Images ########
RONIN_RETH_IMAGE=ghcr.io/conduitxyz/conduit-op-reth:v1.0.0-rc.1
OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.16.5
EIGENDA_PROXY_IMAGE=ghcr.io/layr-labs/eigenda-proxy:2.7.0

######## Chain / Conduit network (saigon | ronin) — used for comments & URL helpers below ########
RONIN_NETWORK=ronin

######## Datadirs (bind mounts) ########
RONIN_RETH_DATADIR=${HOME}/ronin-reth-datadir
RONIN_OP_NODE_DATADIR=${HOME}/ronin-op-node-datadir

######## Layer 1 (Ethereum) ########
L1_RPC=<YOUR_L1_ETH_HTTP_RPC>
L1_BEACON=<YOUR_L1_BEACON_HTTP>

######## Execution (conduit-op-reth) — genesis.json lives under RONIN_RETH_DATADIR ########
# Saigon testnet sequencer:
# RONIN_ROLLUP_SEQUENCER=https://rpc-saigon-testnet-cc58e966ql.t.conduit.xyz
# Ronin mainnet sequencer:
RONIN_ROLLUP_SEQUENCER=https://rpc-ronin-mainnet-bfz9fadqzl.t.conduit.xyz
# Optional pre-bedrock historical RPC (enable the matching line in docker-compose.yml when set)
# RONIN_ROLLUP_HISTORICAL_RPC=https://your-archive.example

# Comma-separated JSON-RPC namespaces
RONIN_RETH_HTTP_API=eth,net,trace,txpool,web3
RONIN_RETH_WS_API=eth,net,trace,txpool,web3

RONIN_RETH_HTTP_PORT=8545
RONIN_RETH_WS_PORT=8546
RONIN_RETH_AUTHRPC_PORT=9551

######## EigenDA proxy (V2) — values below match Conduit preflight for each NETWORK ########
# For saigon: EIGENDA_V2_NETWORK=sepolia_testnet,
#   CERT_VERIFIER=0x17ec4112c4BbD540E2c1fE0A49D264a280176F0D,
#   DISPERSER_RPC=disperser-testnet-sepolia.eigenda.xyz:443
# For ronin mainnet:
EIGENDA_V2_NETWORK=mainnet
EIGENDA_V2_CERT_VERIFIER_ROUTER_OR_IMMUTABLE_VERIFIER_ADDR=0x1be7258230250Bc6a4548F8D59d576a87D216C12
EIGENDA_V2_DISPERSER_RPC=disperser.eigenda.xyz:443

EIGENDA_PROXY_PORT=3100

######## op-node ########
# rollup.json under RONIN_OP_NODE_DATADIR

OP_NODE_RPC_PORT=7545
OP_NODE_P2P_PORT=9222
OP_NODE_METRICS_PORT=7300

# Static peer (required for sync) — pick the line for your network
# Saigon:
# OP_NODE_P2P_STATIC=/ip4/34.187.134.72/tcp/9222/p2p/16Uiu2HAmFyGhL6G7CRgc77zmEeWAdBJA2vFsY9LSYzJQfnCrpWUW
# Ronin:
OP_NODE_P2P_STATIC=/ip4/34.11.218.92/tcp/9222/p2p/16Uiu2HAm2wpj12oJjJJS3EwkpCMMJBw5FvbKivQLLC9TzMmh456G

OP_NODE_P2P_SYNC_ONLYREQTOSTATIC=true
OP_NODE_L1_CONFS=4
OP_NODE_ALTDA_DA_SERVER=http://eigenda-proxy:3100

### Networking — public P2P advertise address ###
EXT_IP=<YOUR_PUBLIC_IP>
