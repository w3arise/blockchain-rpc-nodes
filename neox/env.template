# Neo X mainnet seed node (RPC)
# cp env.template .env and configure before running
#
# Setup:
#   1. ./configure.sh               # create .env and set EXT_IP
#   2. docker compose build
#   3. ./init-database.sh            # mainnet (default)
#   4. docker compose up -d
#
# Snapshot flow: restore archival data into $HOME/neox-data, skip init-database.sh
#
# Docs: https://xdocs.ngd.network/development/run-a-neo-x-node
# Binary: https://github.com/bane-labs/go-ethereum/releases

### Network ###
NETWORK=mainnet
# mainnet chain ID 47763, testnet T4 chain ID 12227332
NETWORK_ID=47763

# Public IP for P2P advertisement (--nat extip); required for incoming peers
EXT_IP=

### Geth release (bane-labs/go-ethereum) — baked into local image at build time ###
# Pins the GitHub release binary and the local Docker tag (neox-geth:<version>).
GETH_VERSION=v0.6.1

### Host paths ###
# Chain data (docker volume mount target inside container: /data)
HOST_DATADIR=$HOME/neox-data

### Ports (host) ###
P2P_PORT=30301
HTTP_PORT=8545
WS_PORT=8546
AUTHRPC_PORT=8561

### Sync ###
SYNC_MODE=full
# Seed/RPC nodes: archive per Neo X docs
GCMODE=full
MAX_PEERS=50
VERBOSITY=3
NODE_IDENTITY=neox-seed

### Bootnodes ###
# From your compose (mainnet). Official docs also list:
# enode://92eec46d...@34.42.6.58:30303, enode://f289fb5c...@34.87.188.162:30303
BOOTNODES=enode://ca6dabad08eda7cdae931df4ee2386a723676538932c5179887b6c6741246cebe60da42d14cad88fd8bb29eda7ccade48f889a422001f85cba0a794c955c8fd5@35.238.46.225:30301

### RPC APIs ###
HTTP_API=admin,eth,debug,miner,net,txpool,personal,web3,dbft
WS_API=eth,net,web3
