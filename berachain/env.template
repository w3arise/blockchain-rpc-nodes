# Berachain mainnet node (bera-reth + beacon-kit)
#
# From scratch:
#   cp env.template .env
#   ./init-database.sh            # beacond init + reth init (genesis/kzg from config/)
#   docker compose up -d
#
# From snapshot:
#   restore into $HOME/berachain-beacond-data and $HOME/berachain-reth-data
#   ./create-jwt.sh && ./run-setup-initialisation.sh && docker compose up -d
#
# Committed under config/: genesis.json, kzg-trusted-setup.json, client.toml
# Generated at init into datadir: app.toml, config.toml (+ node keys)
#
# Data directories (docker-compose volume mounts):
#   $HOME/berachain-reth-data     — execution client chain data
#   $HOME/berachain-beacond-data  — consensus client home (config + data)

### Node identity ###
MONIKER_NAME=berachain-rpc
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

### Docker images ###
BERA_RETH_IMAGE=ghcr.io/berachain/bera-reth:v1.4.2
BEACON_KIT_IMAGE=ghcr.io/berachain/beacon-kit:v1.4.1

### Networking — required for public P2P ###
EXT_IP=<YOUR_PUBLIC_IP>
HTTP_PORT=5545
P2P_PORT=6444
BEACON_P2P_PORT=20656
BEACON_QUIC_PORT=43471
BEACON_QUIC_HOST_PORT=43481

### Consensus-layer P2P (beacond) ###
