# X Layer mainnet — xlayer-reth (op-reth + op-node) — setup (snapshot flow):
#   1. ./create-jwt.sh          # generate config/jwt.txt (shared Engine API secret)
#   2. cp env.template .env     # then set L1_RPC_URL / L1_BEACON_URL / EXT_IP
#   3. restore op-reth data from snapshot into $HOME/xlayer-op-reth-data
#      (latest: https://static.okx.com/cdn/chain/xlayer/snapshot/reth-mainnet-latest)
#   4. docker compose up -d
# Config (rollup + op-reth toml) is committed under config/.
# From scratch instead of snapshot? run ./init-database.sh (genesis + reth init).
#
# This stack is the reth-based alternative to xlayer/ (op-geth). Both are
# X Layer OP Stack nodes; run one or the other (or both, ports don't clash).
# Historical/trace RPC for pre-OP-Stack blocks is forwarded to the legacy
# endpoint via X_LAYER_LEGACY_RPC_URL (xlayer-reth --rpc.legacy-url).

### Layer 1 (Ethereum) — required ###
L1_RPC_URL=<YOUR_L1_ETH_RPC>
L1_BEACON_URL=<YOUR_L1_BEACON>

# Public IP for op-reth P2P NAT advertisement (--nat=extip)
EXT_IP=<YOUR_PUBLIC_IP>

### Docker images ###
OP_STACK_IMAGE_TAG=xlayer/op-node:v0.1.5.1
OP_RETH_IMAGE_TAG=xlayer/xlayer-reth:v0.0.6.3

