### Legacy RPC (historical/trace requests for pre-OP-Stack blocks) ###
# Public OKX endpoint by default; point at your own cdk-erigon if you run one
# (e.g. http://xlayer-cdk-erigon:8545 when attached to the xlayer/ stack network)
X_LAYER_LEGACY_RPC_URL=https://xlayerrpc.okx.com
X_LAYER_LEGACY_RPC_TIMEOUT=30s

