# HashKey Chain mainnet (op-geth + op-node)
# ./configure.sh && ./create-jwt.sh && ./init-database.sh && docker compose up -d
#
# Official run guide: https://docs.hashkeychain.net/docs/Build-on-HashKey-Chain/RPC-Node-Provider
# Upstream compose: https://github.com/HashKeyChain/fullnode-sync

### Images ###
OP_GETH_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-geth:v1.101605.0
OP_NODE_IMAGE=public.ecr.aws/x7e7q5l8/op-node:v1.16.5

### Network ###
EXT_IP=
SEQUENCER_HTTP=https://mainnet.hsk.xyz
GETH_SYNC_MODE=full
GC_MODE=archive

### Host paths ###
HOST_DATADIR=$HOME/hashkey-op-geth-data
HOST_OP_NODE_DATADIR=$HOME/hashkey-op-node-data

### Ports ###
RPC_BIND_ADDR=127.0.0.1
HTTP_PORT=8111
WS_PORT=8112
OP_NODE_RPC_PORT=8113
P2P_PORT=10415
OP_NODE_P2P_PORT=10429

### RPC ###
GAS_CAP=600000000

### op-node L1 ###
OP_NODE_L1_ETH_RPC=<YOUR_L1_ETH_RPC>
OP_NODE_L1_BEACON=<YOUR_L1_BEACON>
OP_NODE_L1_TRUST_RPC=true
OP_NODE_L1_RPC_KIND=standard

### op-node L2 / rollup ###
OP_NODE_LOG_LEVEL=INFO
OP_NODE_L2_ENGINE_KIND=geth
OP_NODE_L2_ENGINE_AUTH=/config/jwt.hex
OP_NODE_L2_ENGINE_RPC=http://hashkey-op-geth:8551
OP_NODE_SYNCMODE=execution-layer
OP_NODE_ROLLUP_CONFIG=/config/rollup.json
OP_NODE_RPC_ADDR=0.0.0.0
OP_NODE_RPC_PORT=8443
OP_NODE_RPC_ENABLE_ADMIN=true
OP_NODE_SAFEDB_PATH=/data
OP_NODE_METRICS_ENABLED=true
OP_NODE_METRICS_ADDR=127.0.0.1
OP_NODE_VERIFIER_L1_CONFS=15
OP_NODE_SEQUENCER_L1_CONFS=15

### op-node P2P (mainnet bootnodes — official docs) ###
OP_NODE_P2P_LISTEN_IP=0.0.0.0
OP_NODE_P2P_LISTEN_TCP=10429
OP_NODE_P2P_LISTEN_UDP=10429
OP_NODE_P2P_ADVERTISE_IP=
OP_NODE_P2P_STATIC=/dns/mainnet-bootnodes.hsk.xyz/tcp/31329/p2p/16Uiu2HAm8itEpr6DRkQhezSWS8WsAGfiLhzv2Y6KK1k2KVGv5PJQ,/dns/mainnet-bootnodes.hsk.xyz/tcp/31330/p2p/16Uiu2HAm79eNjZYakcTmsyifeMQykwArEd6bUU6EQgf3XvCmCKSY,/dns/mainnet-bootnodes.hsk.xyz/tcp/31331/p2p/16Uiu2HAm9WzPWe3szua51vyrj3dZsez89R3fGwAfMexE5568mEyP

# Testnet: chain ID 133, L1 Sepolia, swap genesis/rollup/static-nodes/config,
# SEQUENCER_HTTP=https://testnet.hsk.xyz, and bootnodes from the official testnet template.
